// ========================================================================
//  Prisma Schema — ODOP Connect (Full Production Schema)
//  Uses SQLite for hackathon portability. Switch to PostgreSQL by
//  changing provider to "postgresql" and updating DATABASE_URL.
// ========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── ENUMS (modelled as String since SQLite has no native enums) ────────

// UserRole: FARMER | BUYER | ADMIN
// OrderStatus: PENDING | CONFIRMED | PROCESSING | SHIPPED | IN_TRANSIT | DELIVERED | CANCELLED
// ProposalStatus: PENDING | ACCEPTED | REJECTED | COUNTER | EXPIRED
// TenderStatus: OPEN | CLOSED | AWARDED | CANCELLED
// NotificationType: ORDER | MESSAGE | PROPOSAL | TENDER | SYSTEM | KYC

// ─── USER ──────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  phone         String?
  role          String   @default("FARMER") // FARMER | BUYER | ADMIN
  district      String?
  state         String?
  avatarUrl     String?
  kycStatus     String   @default("PENDING") // PENDING | VERIFIED | REJECTED
  kycDocumentUrl String?
  aadhaarNumber String?
  panNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Reputation Score Fields
  ratingAvg           Float    @default(5.0)
  totalOrders         Int      @default(0)
  successfulDeliveries Int      @default(0)
  cancellationRate    Float    @default(0.0)
  reputationScore     Float    @default(100.0)

  // Relations
  products          Product[]
  ordersAsBuyer     Order[]          @relation("BuyerOrders")
  ordersAsFarmer    Order[]          @relation("FarmerOrders")
  sentMessages      Message[]        @relation("SentMessages")
  receivedMessages  Message[]        @relation("ReceivedMessages")
  proposalsSent     Proposal[]       @relation("ProposalSender")
  proposalsReceived Proposal[]       @relation("ProposalReceiver")
  reviewsGiven      Review[]         @relation("ReviewAuthor")
  reviewsReceived   Review[]         @relation("ReviewTarget")
  notifications     Notification[]
  tenders           Tender[]
  tenderApps        TenderApplication[]
  sampleRequests    SampleRequest[]
  contractsAsBuyer  Contract[]       @relation("ContractBuyer")
  contractsAsFarmer Contract[]       @relation("ContractFarmer")
  refreshTokens     RefreshToken[]
  chatConversations1 ChatConversation[] @relation("ConversationUser1")
  chatConversations2 ChatConversation[] @relation("ConversationUser2")
  chatMessages      ChatMessage[]
  offersAsSender    Offer[]          @relation("OfferSender")
  offersAsReceiver  Offer[]          @relation("OfferReceiver")
  paymentsMade      Payment[]        @relation("PaymentBuyer")
  paymentsReceived  Payment[]        @relation("PaymentSeller")

  @@index([email])
  @@index([role])
  @@index([district])
}
