# ============================================
# ODOP Connect - Root Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================

# This is a master example file showing all possible environment variables
# Individual services have their own .env files:
# - apps/web/.env.local (Frontend)
# - apps/api/.env (Backend API)
# - apps/ai-service/.env (AI Service)

# ============================================
# Quick Start Configuration
# ============================================

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Backend API URL
BACKEND_URL=http://localhost:3001

# AI Service URL
AI_SERVICE_URL=http://localhost:8001

# Database URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/odop_connect

# JWT Secret (CHANGE THIS!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# Service Ports
# ============================================

# Frontend (Next.js)
FRONTEND_PORT=3000

# Backend API (Express)
BACKEND_PORT=3001

# AI Service (FastAPI)
AI_SERVICE_PORT=8001

# Database (PostgreSQL)
DATABASE_PORT=5432

# Redis (Optional)
REDIS_PORT=6379

# ============================================
# Development vs Production
# ============================================

NODE_ENV=development

# Set to 'production' for production deployment
# NODE_ENV=production

# ============================================
# Optional Services
# ============================================

# Payment Gateway (Razorpay)
# RAZORPAY_KEY_ID=rzp_test_xxxxx
# RAZORPAY_KEY_SECRET=xxxxx

# Email Service (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Cloud Storage (AWS S3)
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx
# AWS_S3_BUCKET=odop-connect-uploads

# Analytics (Google Analytics)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Error Tracking (Sentry)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# AI Configuration
# ============================================

# OpenAI API Key (Optional)
# OPENAI_API_KEY=sk-xxxxx

# HuggingFace Token (Optional)
# HF_TOKEN=hf_xxxxx

# ============================================
# Security Notes
# ============================================

# IMPORTANT: Never commit .env files to version control!
# Add .env to your .gitignore file
# Use strong, unique secrets for production
# Rotate secrets regularly
# Use environment-specific values (dev, staging, prod)

# ============================================
# Setup Instructions
# ============================================

# 1. Copy this file to .env in the root directory
# 2. Copy apps/web/.env.local.example to apps/web/.env.local
# 3. Copy apps/api/.env.example to apps/api/.env
# 4. Copy apps/ai-service/.env.example to apps/ai-service/.env
# 5. Fill in your actual values
# 6. Never commit .env files to git!
