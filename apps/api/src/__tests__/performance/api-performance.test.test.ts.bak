import request from 'supertest';
import app from '../../app';

describe('API Performance Tests', () => {
  let authToken: string;

  beforeAll(async () => {
    // Login to get auth token
    const response = await request(app)
      .post('/auth/login')
      .send({
        email: 'testbuyer@example.com',
        password: 'Test123!@#'
      });

    authToken = response.body.token;
  });

  describe('Response Time Tests', () => {
    it('should respond to GET /buyer/suppliers within 500ms', async () => {
      const start = Date.now();
      
      await request(app)
        .get('/buyer/suppliers')
        .set('Authorization', `Bearer ${authToken}`)
        .expect(200);

      const duration = Date.now() - start;
      expect(duration).toBeLessThan(500);
      console.log(`GET /buyer/suppliers: ${duration}ms`);
    });

    it('should respond to GET /buyer/bids within 500ms', async () => {
      const start = Date.now();
      
      await request(app)
        .get('/buyer/bids')
        .set('Authorization', `Bearer ${authToken}`)
        .expect(200);

      const duration = Date.now() - start;
      expect(duration).toBeLessThan(500);
      console.log(`GET /buyer/bids: ${duration}ms`);
    });

    it('should respond to GET /buyer/orders within 500ms', async () => {
      const start = Date.now();
      
      await request(app)
        .get('/buyer/orders')
        .set('Authorization', `Bearer ${authToken}`)
        .expect(200);

      const duration = Date.now() - start;
      expect(duration).toBeLessThan(500);
      console.log(`GET /buyer/orders: ${duration}ms`);
    });

    it('should respond to GET /buyer/analytics/insights within 1000ms', async () => {
      const start = Date.now();
      
      await request(app)
        .get('/buyer/analytics/insights')
        .set('Authorization', `Bearer ${authToken}`)
        .expect(200);

      const duration = Date.now() - start;
      expect(duration).toBeLessThan(1000);
      console.log(`GET /buyer/analytics/insights: ${duration}ms`);
    });
  });

  describe('Concurrent Request Tests', () => {
    it('should handle 10 concurrent requests', async () => {
      const requests = Array(10).fill(null).map(() =>
        request(app)
          .get('/buyer/suppliers')
          .set('Authorization', `Bearer ${authToken}`)
      );

      const start = Date.now();
      const responses = await Promise.all(requests);
      const duration = Date.now() - start;

      responses.forEach(response => {
        expect(response.status).toBe(200);
      });

      console.log(`10 concurrent requests: ${duration}ms`);
      expect(duration).toBeLessThan(2000);
    });

    it('should handle 50 concurrent requests', async () => {
      const requests = Array(50).fill(null).map(() =>
        request(app)
          .get('/buyer/bids')
          .set('Authorization', `Bearer ${authToken}`)
      );

      const start = Date.now();
      const responses = await Promise.all(requests);
      const duration = Date.now() - start;

      responses.forEach(response => {
        expect(response.status).toBe(200);
      });

      console.log(`50 concurrent requests: ${duration}ms`);
      expect(duration).toBeLessThan(5000);
    });
  });

  describe('Pagination Performance', () => {
    it('should handle large page sizes efficiently', async () => {
      const start = Date.now();
      
      await request(app)
        .get('/buyer/suppliers?limit=100')
        .set('Authorization', `Bearer ${authToken}`)
        .expect(200);

      const duration = Date.now() - start;
      expect(duration).toBeLessThan(1000);
      console.log(`Large page (100 items): ${duration}ms`);
    });
  });

  describe('Filter Performance', () => {
    it('should handle complex filters efficiently', async () => {
      const start = Date.now();
      
      await request(app)
        .get('/buyer/suppliers?district=Pune&minRating=4.5&category=Wheat')
        .set('Authorization', `Bearer ${authToken}`)
        .expect(200);

      const duration = Date.now() - start;
      expect(duration).toBeLessThan(800);
      console.log(`Complex filters: ${duration}ms`);
    });
  });
});
