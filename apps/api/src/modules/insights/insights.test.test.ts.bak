/**
 * Integration tests for Price Intelligence module
 * Tests the three main endpoints: price-trends, price-forecast, and price-alert
 */

import request from 'supertest';
import { app } from '../../app';
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

describe('Price Intelligence API', () => {
  let authToken: string;
  let userId: string;

  beforeAll(async () => {
    // Create a test user and get auth token
    const registerResponse = await request(app)
      .post('/auth/register')
      .send({
        name: 'Test Farmer',
        email: 'test.farmer@example.com',
        password: 'password123',
        role: 'FARMER',
        district: 'Pune',
        state: 'Maharashtra'
      });

    if (registerResponse.body.data) {
      authToken = registerResponse.body.data.accessToken;
      userId = registerResponse.body.data.user.id;
    }
  });

  afterAll(async () => {
    // Cleanup test data
    if (userId) {
      await prisma.priceAlert.deleteMany({ where: { userId } });
      await prisma.user.delete({ where: { id: userId } });
    }
    await prisma.$disconnect();
  });

  describe('GET /insights/price-trends', () => {
    it('should return price trends for a category', async () => {
      const response = await request(app)
        .get('/insights/price-trends')
        .query({
          category: 'GRAIN',
          district: 'Pune',
          state: 'Maharashtra',
          days: 30
        })
        .set('Authorization', `Bearer ${authToken}`);

      expect(response.status).toBe(200);
      expect(response.body.success).toBe(true);
      expect(response.body.data).toHaveProperty('category');
      expect(response.body.data).toHaveProperty('currentPrice');
      expect(response.body.data).toHaveProperty('trend');
      expect(response.body.data).toHaveProperty('historicalData');
      expect(response.body.data).toHaveProperty('insights');
    });

    it('should return 400 if category is missing', async () => {
      const response = await request(app)
        .get('/insights/price-trends')
        .set('Authorization', `Bearer ${authToken}`);

      expect(response.status).toBe(400);
      expect(response.body.error).toBe('Category is required');
    });

    it('should return 401 if not authenticated', async () => {
      const response = await request(app)
        .get('/insights/price-trends')
        .query({ category: 'GRAIN' });

      expect(response.status).toBe(401);
    });
  });

  describe('GET /insights/price-forecast', () => {
    it('should return price forecast with AI predictions', async () => {
      const response = await request(app)
        .get('/insights/price-forecast')
        .query({
          category: 'GRAIN',
          district: 'Pune',
          state: 'Maharashtra',
          quantity: 100,
          qualityGrade: 'A'
        })
        .set('Authorization', `Bearer ${authToken}`);

      expect(response.status).toBe(200);
      expect(response.body.success).toBe(true);
      expect(response.body.data).toHaveProperty('predictedPrice');
      expect(response.body.data).toHaveProperty('confidence');
      expect(response.body.data).toHaveProperty('forecast');
      expect(response.body.data).toHaveProperty('recommendations');
      expect(Array.isArray(response.body.data.forecast)).toBe(true);
      expect(response.body.data.forecast.length).toBeGreaterThan(0);
    });

    it('should return 400 if required parameters are missing', async () => {
      const response = await request(app)
        .get('/insights/price-forecast')
        .query({ category: 'GRAIN' })
        .set('Authorization', `Bearer ${authToken}`);

      expect(response.status).toBe(400);
      expect(response.body.error).toContain('required');
    });
  });

  describe('POST /insights/price-alert', () => {
    it('should create a price alert', async () => {
      const response = await request(app)
        .post('/insights/price-alert')
        .set('Authorization', `Bearer ${authToken}`)
        .send({
          category: 'GRAIN',
          targetPrice: 5000,
          condition: 'ABOVE',
          district: 'Pune',
          state: 'Maharashtra'
        });

      expect(response.status).toBe(200);
      expect(response.body.success).toBe(true);
      expect(response.body.data).toHaveProperty('id');
      expect(response.body.data.category).toBe('GRAIN');
      expect(response.body.data.targetPrice).toBe(5000);
      expect(response.body.data.condition).toBe('ABOVE');
    });

    it('should return 400 if condition is invalid', async () => {
      const response = await request(app)
        .post('/insights/price-alert')
        .set('Authorization', `Bearer ${authToken}`)
        .send({
          category: 'GRAIN',
          targetPrice: 5000,
          condition: 'INVALID'
        });

      expect(response.status).toBe(400);
      expect(response.body.error).toContain('ABOVE or BELOW');
    });
  });

  describe('GET /insights/price-alerts', () => {
    it('should return user price alerts', async () => {
      // Create an alert first
      await request(app)
        .post('/insights/price-alert')
        .set('Authorization', `Bearer ${authToken}`)
        .send({
          category: 'VEGETABLE',
          targetPrice: 3000,
          condition: 'BELOW'
        });

      const response = await request(app)
        .get('/insights/price-alerts')
        .set('Authorization', `Bearer ${authToken}`);

      expect(response.status).toBe(200);
      expect(response.body.success).toBe(true);
      expect(Array.isArray(response.body.data)).toBe(true);
      expect(response.body.data.length).toBeGreaterThan(0);
    });
  });

  describe('DELETE /insights/price-alert/:alertId', () => {
    it('should delete a price alert', async () => {
      // Create an alert first
      const createResponse = await request(app)
        .post('/insights/price-alert')
        .set('Authorization', `Bearer ${authToken}`)
        .send({
          category: 'FRUIT',
          targetPrice: 4000,
          condition: 'ABOVE'
        });

      const alertId = createResponse.body.data.id;

      const deleteResponse = await request(app)
        .delete(`/insights/price-alert/${alertId}`)
        .set('Authorization', `Bearer ${authToken}`);

      expect(deleteResponse.status).toBe(200);
      expect(deleteResponse.body.success).toBe(true);
    });
  });
});
