# ========================================================================
# Real-Time Marketplace Ecosystem - Environment Configuration
# ========================================================================

# ─── DATABASE ──────────────────────────────────────────────────────────
# PostgreSQL connection string for production
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace_db"

# ─── SERVER ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
API_URL="http://localhost:3001"

# ─── FRONTEND ──────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── JWT AUTHENTICATION ────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── REDIS CACHE ──────────────────────────────────────────────────────
# Redis connection for caching and session management
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0

# ─── WEBSOCKET (Socket.IO) ────────────────────────────────────────────
# WebSocket configuration for real-time features
WEBSOCKET_PORT=3002
WEBSOCKET_CORS_ORIGIN="http://localhost:3000"
WEBSOCKET_PING_INTERVAL=25000
WEBSOCKET_PING_TIMEOUT=60000

# ─── FILE STORAGE (S3-Compatible) ─────────────────────────────────────
# S3 or S3-compatible storage (MinIO, DigitalOcean Spaces, AWS S3, etc.)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="marketplace"
S3_REGION="us-east-1"
S3_USE_PATH_STYLE_URL=true
S3_PUBLIC_URL="http://localhost:9000/marketplace"

# File upload constraints
MAX_FILE_SIZE=10485760
MAX_IMAGE_SIZE=5242880
UPLOAD_DIR="uploads"

# ─── PAYMENT GATEWAY (Razorpay) ────────────────────────────────────────
# Razorpay payment gateway integration
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# ─── AI SERVICE ────────────────────────────────────────────────────────
# Python FastAPI service for quality analysis
AI_SERVICE_URL="http://localhost:8001"
AI_SERVICE_TIMEOUT=15000
AI_QUALITY_ANALYSIS_ENABLED=true

# ─── VOICE SERVICE ────────────────────────────────────────────────────
# Speech-to-text and text-to-speech services
VOICE_SERVICE_PROVIDER="google"
GOOGLE_CLOUD_PROJECT_ID="your-project-id"
GOOGLE_CLOUD_CREDENTIALS_PATH="./credentials.json"

# ─── EMAIL SERVICE ────────────────────────────────────────────────────
# Email configuration for notifications and invoices
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@marketplace.com"
EMAIL_FROM_NAME="Marketplace"

# ─── LOGGING ───────────────────────────────────────────────────────────
LOG_LEVEL="info"
LOG_FORMAT="json"

# ─── SECURITY ──────────────────────────────────────────────────────────
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS configuration
CORS_ORIGIN="http://localhost:3000"
CORS_CREDENTIALS=true

# ─── MONITORING & OBSERVABILITY ────────────────────────────────────────
# Application Performance Monitoring
APM_ENABLED=false
APM_SERVICE_NAME="marketplace-api"
APM_SERVER_URL="http://localhost:8200"

# ─── FEATURE FLAGS ─────────────────────────────────────────────────────
FEATURE_REAL_TIME_ENABLED=true
FEATURE_AI_QUALITY_ENABLED=true
FEATURE_VOICE_ENABLED=true
FEATURE_PAYMENT_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true

# ─── MARKETPLACE CONFIGURATION ─────────────────────────────────────────
# Default marketplace settings
DEFAULT_CURRENCY="INR"
TAX_RATE=0.18
COMMISSION_RATE=0.05
MIN_ORDER_VALUE=100
MAX_ORDER_VALUE=1000000

# ─── QUALITY GRADES ───────────────────────────────────────────────────
# Quality grade thresholds (0-100 score)
QUALITY_GRADE_A_PLUS_MIN=90
QUALITY_GRADE_A_MIN=75
QUALITY_GRADE_B_PLUS_MIN=60
QUALITY_GRADE_B_MIN=40

# ─── NOTIFICATION SETTINGS ────────────────────────────────────────────
# Real-time notification configuration
NOTIFICATION_RETENTION_DAYS=30
NOTIFICATION_BATCH_SIZE=100

# ─── ANALYTICS ────────────────────────────────────────────────────────
# Analytics and reporting
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=365

# ─── ENVIRONMENT-SPECIFIC SETTINGS ────────────────────────────────────
# Development
DEBUG=false
SEED_DATABASE=false

# Production
PRODUCTION_MODE=false
ENABLE_HTTPS=false
SSL_CERT_PATH=""
SSL_KEY_PATH=""
