// ========================================================================
// AgriTrust - Agri-B2B Marketplace Platform
// Prisma Schema for PostgreSQL
// ========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────────────────

enum Role {
  FARMER
  BUYER
  FPO
}

enum Language {
  en
  hi
  mr
}

enum CropGrade {
  A
  B
  C
}

enum CropStatus {
  LISTED
  SENT_TO_FPO
  ACCEPTED
  REJECTED
  SOLD
  PENDING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum FPOLinkStatus {
  NONE
  PENDING
  LINKED
}

enum LinkRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KYCStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum KYCDocumentType {
  AADHAAR
  PAN_CARD
  GST_CERTIFICATE
  FPO_REGISTRATION
  BANK_PASSBOOK
}

enum LogisticsStatus {
  REQUESTED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

// ─── USER ──────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  name              String
  phone             String    @unique
  email             String?   @unique
  passwordHash      String
  role              Role
  
  // KYC General Info
  kycStatus         KYCStatus @default(NOT_SUBMITTED)
  rejectionReason   String?
  aadhaar           String?   // For Farmers
  gst               String?   // For Buyers/FPOs
  pan               String?
  bankAccount       String?
  ifsc              String?
  bankName          String?
  
  // Preferences
  language          Language  @default(en)
  kycVerified       Boolean   @default(false) // Deprecated in favor of kycStatus but keeping for compatibility
  
  // FPO Linking (for farmers)
  linkedFpoId       String?
  fpoLinkStatus     FPOLinkStatus @default(NONE)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  kycDocuments      KYCDocument[]
  farm              Farm?
  fpo               FPO?
  crops             Crop[]
  ordersAsBuyer     Order[]   @relation("BuyerOrders")
  wallet            Wallet?
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  farmerEarnings    FarmerEarning[]
  fpoChats          FPOChat[]
  fpoChatMessages   FPOChatMessage[]
  fpoLinkRequests   FPOLinkRequest[]
  bankDetails       BankDetails[]
  complianceLogs    ComplianceLog[]
  qualityScans      QualityScan[] @relation("FarmerQualityScans")

  @@index([phone])
  @@index([role])
}

model KYCDocument {
  id                String          @id @default(uuid())
  userId            String
  type              KYCDocumentType
  documentUrl       String
  verifiedAt        DateTime?
  createdAt         DateTime        @default(now())

  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── FARM ──────────────────────────────────────────────────────────────

model Farm {
  id                String    @id @default(uuid())
  farmerId          String    @unique
  location          String
  district          String
  state             String
  areaAcres         Float
  photos            String[]  // Array of photo URLs
  soilType          String?
  irrigationType    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  farmer            User      @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([farmerId])
  @@index([district])
}

// ─── FPO ───────────────────────────────────────────────────────────────

model FPO {
  id                String    @id @default(uuid())
  adminUserId       String    @unique
  name              String
  registrationNo    String    @unique
  bankAccount       String
  ifsc              String
  district          String
  state             String
  commissionRate    Float     @default(5.0) // FPO commission percentage
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  admin             User      @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  farmers           FPOFarmer[]
  aggregatedLots    AggregatedLot[]
  chats             FPOChat[]
  logistics         FPOLogistics[]
  payoutSplits      FPOPayoutSplit[]

  @@index([adminUserId])
  @@index([district])
}

// ─── FPO FARMER ────────────────────────────────────────────────────────

model FPOFarmer {
  id                String    @id @default(uuid())
  fpoId             String
  name              String
  phone             String
  aadhaar           String
  bankAccount       String?
  ifsc              String?
  photos            String[]  // Array of photo URLs
  district          String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  fpo               FPO       @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  crops             Crop[]
  payoutSplits      FPOPayoutSplit[]

  @@index([fpoId])
  @@index([phone])
}

// ─── CROP ──────────────────────────────────────────────────────────────

model Crop {
  id                String      @id @default(uuid())
  farmerId          String?
  fpoFarmerId       String?
  fpoId             String?
  
  cropName          String
  images            String[]    @default([])
  expectedHarvestDate DateTime?
  category          String      // Vegetables, Fruits, Grains
  variety           String
  quantity          Float       // in kg
  pricePerKg        Float
  grade             CropGrade
  isAggregated      Boolean     @default(false)
  qualityCertUrl    String?
  status            CropStatus  @default(LISTED)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  farmer            User?       @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  fpoFarmer         FPOFarmer?  @relation(fields: [fpoFarmerId], references: [id], onDelete: Cascade)
  orders            Order[]
  aggregatedLot     AggregatedLot? @relation(fields: [aggregatedLotId], references: [id])
  aggregatedLotId   String?
  payoutSplits      FPOPayoutSplit[]
  qualityCertificates QualityCertificate[]
  qualityScans      QualityScan[] @relation("CropQualityScans")

  @@index([farmerId])
  @@index([fpoFarmerId])
  @@index([cropName])
  @@index([status])
  @@index([isAggregated])
}

// ─── AGGREGATED LOT ────────────────────────────────────────────────────

model AggregatedLot {
  id                String      @id @default(uuid())
  fpoId             String
  cropName          String
  totalQuantity     Float       // Combined quantity in kg
  pricePerKg        Float       // Weighted average price
  qualityCertUrl    String?
  status            CropStatus  @default(LISTED)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  fpo               FPO         @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  crops             Crop[]
  orders            Order[]
  qualityCertificates QualityCertificate[]

  @@index([fpoId])
  @@index([cropName])
  @@index([status])
}

// ─── ORDER ─────────────────────────────────────────────────────────────

model Order {
  id                String        @id @default(uuid())
  buyerId           String
  cropId            String?
  lotId             String?
  
  quantity          Float
  totalAmount       Float
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING) // Payment tracking
  escrowStatus      EscrowStatus  @default(HELD)
  deliveryAddress   String
  
  // Tracking fields
  trackingNumber    String?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  deliveryProof     String[]      @default([]) // Array of photo URLs
  deliveryNotes     String?
  confirmedByBuyer  Boolean       @default(false)
  confirmedAt       DateTime?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  buyer             User          @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  crop              Crop?         @relation(fields: [cropId], references: [id], onDelete: SetNull)
  lot               AggregatedLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  escrowTransaction EscrowTransaction?
  logistics         FPOLogistics?
  payoutSplits      FPOPayoutSplit[]
  trackingEvents    OrderTrackingEvent[]

  @@index([buyerId])
  @@index([cropId])
  @@index([lotId])
  @@index([status])
  @@index([paymentStatus])
  @@index([escrowStatus])
  @@index([trackingNumber])
}

// ─── ESCROW TRANSACTION ────────────────────────────────────────────────

model EscrowTransaction {
  id                String        @id @default(uuid())
  orderId           String        @unique
  buyerId           String
  sellerId          String        // Farmer or FPO ID
  amount            Float
  status            EscrowStatus  @default(HELD)
  razorpayOrderId   String?       // Razorpay order ID
  razorpayPaymentId String?       // Razorpay payment ID
  razorpaySignature String?       // Payment signature
  heldAt            DateTime      @default(now())
  releasedAt        DateTime?
  refundedAt        DateTime?
  refundReason      String?

  // Relations
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([razorpayOrderId])
}

// ─── WALLET ────────────────────────────────────────────────────────────

model Wallet {
  id                String    @id @default(uuid())
  userId            String    @unique
  balance           Float     @default(0)
  heldBalance       Float     @default(0) // Amount held in escrow
  currency          String    @default("INR")
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      WalletTransaction[]

  @@index([userId])
}

// ─── WALLET TRANSACTION ────────────────────────────────────────────────

model WalletTransaction {
  id                String    @id @default(uuid())
  walletId          String
  type              String    // ADD_FUNDS, DEBIT, ESCROW_HOLD, ESCROW_RELEASE
  amount            Float
  balanceBefore     Float
  balanceAfter      Float
  description       String?
  referenceId       String?   // Order ID
  
  createdAt         DateTime  @default(now())

  // Relations
  wallet            Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

// ─── MARKET PRICE ──────────────────────────────────────────────────────

model MarketPrice {
  id              String   @id @default(uuid())
  cropName        String
  variety         String
  district        String
  state           String
  minPrice        Float
  maxPrice        Float
  modalPrice      Float
  arrivalQuantity Float
  date            DateTime
  createdAt       DateTime @default(now())

  @@index([cropName, district, date])
}

// ─── MESSAGE (Chat) ────────────────────────────────────────────────────

model Message {
  id                String    @id @default(uuid())
  senderId          String
  receiverId        String
  orderId           String?
  content           String
  read              Boolean   @default(false)
  
  createdAt         DateTime  @default(now())

  // Relations
  sender            User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver          User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([orderId])
  @@index([createdAt])
}

// ─── QUALITY CERTIFICATE ───────────────────────────────────────────────

enum CertificateType {
  LAB_TEST
  FPO_VERIFIED
  ORGANIC
  GOVERNMENT
  AI_GENERATED
}

model QualityCertificate {
  id                String          @id @default(uuid())
  cropId            String?
  lotId             String?
  uploadedBy        String
  certificateType   CertificateType @default(FPO_VERIFIED)
  certificateNumber String?
  issuerName        String?
  issueDate         DateTime?
  expiryDate        DateTime?
  fileUrl           String
  verifiedByFPO     Boolean         @default(false)
  verifiedBy        String?         // FPO admin user ID who verified
  verifiedAt        DateTime?
  aiScore           Float?
  notes             String?
  
  uploadedAt        DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  crop              Crop?           @relation(fields: [cropId], references: [id])
  lot               AggregatedLot?  @relation(fields: [lotId], references: [id])

  @@index([cropId])
  @@index([lotId])
  @@index([uploadedBy])
  @@index([certificateType])
  @@index([verifiedByFPO])
}

// ─── FARMER EARNING ────────────────────────────────────────────────────

model FarmerEarning {
  id                String    @id @default(uuid())
  farmerId          String
  orderId           String
  amount            Float
  platformFee       Float     @default(0)
  status            PaymentStatus @default(PENDING)
  
  createdAt         DateTime  @default(now())
  paidAt            DateTime?

  // Relations
  farmer            User      @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([farmerId])
  @@index([orderId])
  @@index([status])
}

// ─── FPO CHAT ──────────────────────────────────────────────────────────

model FPOChat {
  id                String    @id @default(uuid())
  fpoId             String
  buyerId           String
  orderId           String?
  lastMessage       String?
  lastMessageAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  fpo               FPO       @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  buyer             User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  messages          FPOChatMessage[]

  @@index([fpoId])
  @@index([buyerId])
}

model FPOChatMessage {
  id                String    @id @default(uuid())
  chatId            String
  senderId          String
  content           String
  attachments       String[]
  read              Boolean   @default(false)
  createdAt         DateTime  @default(now())

  // Relations
  chat              FPOChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender            User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
}

// ─── FPO LOGISTICS ─────────────────────────────────────────────────────

model FPOLogistics {
  id                String    @id @default(uuid())
  orderId           String    @unique
  fpoId             String
  trackingNumber    String?
  carrier           String?
  status            LogisticsStatus @default(REQUESTED)
  
  // Driver & Vehicle Info
  driverName        String?
  driverPhone       String?
  vehicleNumber     String?
  
  // Location Coordinates
  pickupLocation    String?
  pickupLat         Float?
  pickupLng         Float?
  dropLocation      String?
  dropLat           Float?
  dropLng           Float?
  currentLat        Float?
  currentLng        Float?
  
  // Timestamps for each status
  assignedAt        DateTime?
  pickedUpAt        DateTime?
  inTransitAt       DateTime?
  outForDeliveryAt  DateTime?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  
  notes             String?
  deliveryProof     String[]  @default([]) // Array of photo URLs
  deliveryNotes     String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fpo               FPO       @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  events            LogisticsEvent[]

  @@index([orderId])
  @@index([fpoId])
  @@index([status])
  @@index([driverPhone])
  @@index([vehicleNumber])
}

model LogisticsEvent {
  id                String    @id @default(uuid())
  logisticsId       String
  status            String
  location          String?
  description       String?
  timestamp         DateTime  @default(now())

  // Relations
  logistics         FPOLogistics @relation(fields: [logisticsId], references: [id], onDelete: Cascade)

  @@index([logisticsId])
}

// ─── FPO PAYOUT SPLIT ──────────────────────────────────────────────────

model FPOPayoutSplit {
  id                String    @id @default(uuid())
  orderId           String
  fpoId             String
  fpoFarmerId       String
  cropId            String
  farmerShare       Float     // Amount for farmer
  fpoCommission     Float     // FPO commission
  totalAmount       Float     // Total amount
  status            String    @default("PENDING") // PENDING, PAID
  paidAt            DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fpo               FPO       @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  fpoFarmer         FPOFarmer @relation(fields: [fpoFarmerId], references: [id], onDelete: Cascade)
  crop              Crop      @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([fpoId])
  @@index([fpoFarmerId])
}

// ─── FPO LINK REQUEST ──────────────────────────────────────────────────

model FPOLinkRequest {
  id                String            @id @default(uuid())
  farmerId          String
  fpoId             String
  status            LinkRequestStatus @default(PENDING)
  farmerName        String
  farmerPhone       String
  farmerDistrict    String?
  farmerAadhaar     String?
  message           String?           // Optional message from farmer
  rejectionReason   String?           // Reason if rejected
  reviewedBy        String?           // FPO admin user ID who reviewed
  reviewedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  farmer            User              @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([farmerId])
  @@index([fpoId])
  @@index([status])
  @@unique([farmerId, fpoId]) // Prevent duplicate requests
}

// ─── ORDER TRACKING EVENT ──────────────────────────────────────────────

model OrderTrackingEvent {
  id                String    @id @default(uuid())
  orderId           String
  status            String    // PLACED, CONFIRMED, PACKED, PICKED_UP, IN_TRANSIT, OUT_FOR_DELIVERY, DELIVERED
  location          String?
  latitude          Float?
  longitude         Float?
  description       String?
  updatedBy         String    // User ID who created this event
  updatedByRole     Role      // Role of the user
  photos            String[]  @default([])
  timestamp         DateTime  @default(now())

  // Relations
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([timestamp])
}

// ─── BANK DETAILS ──────────────────────────────────────────────────────

model BankDetails {
  id                  String    @id @default(uuid())
  userId              String
  accountHolderName   String
  accountNumber       String    // Encrypted
  ifscCode            String
  bankName            String
  branchName          String
  accountType         String    // SAVINGS, CURRENT
  isVerified          Boolean   @default(false)
  isPrimary           Boolean   @default(true)
  verifiedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isVerified])
  @@unique([userId, isPrimary])
}

// ─── COMPLIANCE LOGS ──────────────────────────────────────────────────

model ComplianceLog {
  id          String   @id @default(uuid())
  userId      String
  type        String   // LIVELINESS_CHECK, AADHAAR_VERIFICATION, GEO_AUDIT, etc.
  status      String   // PASSED, FAILED, SUCCESS, VALID, EXPIRED, etc.
  details     Json     // Detailed result data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── QUALITY SCAN ──────────────────────────────────────────────────────

model QualityScan {
  id          String   @id @default(uuid())
  farmerId    String
  productId   String?
  imageUrl    String   @db.Text
  grade       String   // A+, A, B+, B, C
  score       Int      // 0-100
  defects     Int      @default(0)
  freshness   Int      @default(0) // 0-100
  color       Int      @default(0) // 0-100
  size        Int      @default(0) // 0-100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  farmer      User     @relation("FarmerQualityScans", fields: [farmerId], references: [id], onDelete: Cascade)
  product     Crop?    @relation("CropQualityScans", fields: [productId], references: [id], onDelete: SetNull)

  @@index([farmerId])
  @@index([productId])
  @@index([createdAt])
  @@index([grade])
}
