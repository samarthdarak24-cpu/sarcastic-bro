// ========================================================================
// AgriTrust - Agri-B2B Marketplace Platform
// Prisma Schema for PostgreSQL
// ========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────────────────

enum Role {
  FARMER
  BUYER
  FPO
}

enum Language {
  en
  hi
  mr
}

enum CropGrade {
  A
  B
  C
}

enum CropStatus {
  LISTED
  SOLD
  PENDING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── USER ──────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  name              String
  phone             String    @unique
  email             String?   @unique
  passwordHash      String
  role              Role
  
  // KYC Fields
  aadhaar           String?   // For Farmers
  gst               String?   // For Buyers
  bankAccount       String?
  ifsc              String?
  bankName          String?
  
  // Preferences
  language          Language  @default(en)
  kycVerified       Boolean   @default(false)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  farm              Farm?
  fpo               FPO?
  crops             Crop[]
  ordersAsBuyer     Order[]   @relation("BuyerOrders")
  wallet            Wallet?
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  farmerEarnings    FarmerEarning[]
  fpoChats          FPOChat[]
  fpoChatMessages   FPOChatMessage[]

  @@index([phone])
  @@index([role])
}

// ─── FARM ──────────────────────────────────────────────────────────────

model Farm {
  id                String    @id @default(uuid())
  farmerId          String    @unique
  location          String
  district          String
  state             String
  areaAcres         Float
  photos            String[]  // Array of photo URLs
  soilType          String?
  irrigationType    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  farmer            User      @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([farmerId])
  @@index([district])
}

// ─── FPO ───────────────────────────────────────────────────────────────

model FPO {
  id                String    @id @default(uuid())
  adminUserId       String    @unique
  name              String
  registrationNo    String    @unique
  bankAccount       String
  ifsc              String
  district          String
  state             String
  commissionRate    Float     @default(5.0) // FPO commission percentage
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  admin             User      @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  farmers           FPOFarmer[]
  aggregatedLots    AggregatedLot[]
  chats             FPOChat[]
  logistics         FPOLogistics[]
  payoutSplits      FPOPayoutSplit[]

  @@index([adminUserId])
  @@index([district])
}

// ─── FPO FARMER ────────────────────────────────────────────────────────

model FPOFarmer {
  id                String    @id @default(uuid())
  fpoId             String
  name              String
  phone             String
  aadhaar           String
  bankAccount       String?
  ifsc              String?
  photos            String[]  // Array of photo URLs
  district          String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  fpo               FPO       @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  crops             Crop[]
  payoutSplits      FPOPayoutSplit[]

  @@index([fpoId])
  @@index([phone])
}

// ─── CROP ──────────────────────────────────────────────────────────────

model Crop {
  id                String      @id @default(uuid())
  farmerId          String?
  fpoFarmerId       String?
  fpoId             String?
  
  cropName          String
  category          String      // Vegetables, Fruits, Grains
  variety           String
  quantity          Float       // in kg
  pricePerKg        Float
  grade             CropGrade
  isAggregated      Boolean     @default(false)
  qualityCertUrl    String?
  status            CropStatus  @default(LISTED)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  farmer            User?       @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  fpoFarmer         FPOFarmer?  @relation(fields: [fpoFarmerId], references: [id], onDelete: Cascade)
  orders            Order[]
  aggregatedLot     AggregatedLot? @relation(fields: [aggregatedLotId], references: [id])
  aggregatedLotId   String?
  payoutSplits      FPOPayoutSplit[]

  @@index([farmerId])
  @@index([fpoFarmerId])
  @@index([cropName])
  @@index([status])
  @@index([isAggregated])
}

// ─── AGGREGATED LOT ────────────────────────────────────────────────────

model AggregatedLot {
  id                String      @id @default(uuid())
  fpoId             String
  cropName          String
  totalQuantity     Float       // Combined quantity in kg
  pricePerKg        Float       // Weighted average price
  qualityCertUrl    String?
  status            CropStatus  @default(LISTED)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  fpo               FPO         @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  crops             Crop[]
  orders            Order[]

  @@index([fpoId])
  @@index([cropName])
  @@index([status])
}

// ─── ORDER ─────────────────────────────────────────────────────────────

model Order {
  id                String        @id @default(uuid())
  buyerId           String
  cropId            String?
  lotId             String?
  
  quantity          Float
  totalAmount       Float
  status            OrderStatus   @default(PENDING)
  escrowStatus      EscrowStatus  @default(HELD)
  deliveryAddress   String
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  buyer             User          @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  crop              Crop?         @relation(fields: [cropId], references: [id], onDelete: SetNull)
  lot               AggregatedLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  escrowTransaction EscrowTransaction?
  logistics         FPOLogistics?
  payoutSplits      FPOPayoutSplit[]

  @@index([buyerId])
  @@index([cropId])
  @@index([lotId])
  @@index([status])
  @@index([escrowStatus])
}

// ─── ESCROW TRANSACTION ────────────────────────────────────────────────

model EscrowTransaction {
  id                String        @id @default(uuid())
  orderId           String        @unique
  buyerId           String
  sellerId          String        // Farmer or FPO ID
  amount            Float
  status            EscrowStatus  @default(HELD)
  razorpayPaymentId String?
  heldAt            DateTime      @default(now())
  releasedAt        DateTime?

  // Relations
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

// ─── WALLET ────────────────────────────────────────────────────────────

model Wallet {
  id                String    @id @default(uuid())
  userId            String    @unique
  balance           Float     @default(0)
  currency          String    @default("INR")
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      WalletTransaction[]

  @@index([userId])
}

// ─── WALLET TRANSACTION ────────────────────────────────────────────────

model WalletTransaction {
  id                String    @id @default(uuid())
  walletId          String
  type              String    // ADD_FUNDS, DEBIT, ESCROW_HOLD, ESCROW_RELEASE
  amount            Float
  balanceBefore     Float
  balanceAfter      Float
  description       String?
  referenceId       String?   // Order ID
  
  createdAt         DateTime  @default(now())

  // Relations
  wallet            Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

// ─── MARKET PRICE ──────────────────────────────────────────────────────

model MarketPrice {
  id                String    @id @default(uuid())
  cropName          String
  variety           String
  grade             CropGrade
  pricePerKg        Float
  district          String
  recordedAt        DateTime  @default(now())

  @@index([cropName])
  @@index([variety])
  @@index([district])
  @@index([recordedAt])
}

// ─── MESSAGE (Chat) ────────────────────────────────────────────────────

model Message {
  id                String    @id @default(uuid())
  senderId          String
  receiverId        String
  orderId           String?
  content           String
  read              Boolean   @default(false)
  
  createdAt         DateTime  @default(now())

  // Relations
  sender            User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver          User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([orderId])
  @@index([createdAt])
}

// ─── QUALITY CERTIFICATE ───────────────────────────────────────────────

model QualityCertificate {
  id                String    @id @default(uuid())
  cropId            String?
  lotId             String?
  uploadedBy        String
  fileUrl           String
  verifiedByFPO     Boolean   @default(false)
  aiScore           Float?
  
  uploadedAt        DateTime  @default(now())

  @@index([cropId])
  @@index([lotId])
  @@index([uploadedBy])
}

// ─── FARMER EARNING ────────────────────────────────────────────────────

model FarmerEarning {
  id                String    @id @default(uuid())
  farmerId          String
  orderId           String
  amount            Float
  platformFee       Float     @default(0)
  status            PaymentStatus @default(PENDING)
  
  createdAt         DateTime  @default(now())
  paidAt            DateTime?

  // Relations
  farmer            User      @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([farmerId])
  @@index([orderId])
  @@index([status])
}

// ─── FPO CHAT ──────────────────────────────────────────────────────────

model FPOChat {
  id                String    @id @default(uuid())
  fpoId             String
  buyerId           String
  orderId           String?
  lastMessage       String?
  lastMessageAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  fpo               FPO       @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  buyer             User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  messages          FPOChatMessage[]

  @@index([fpoId])
  @@index([buyerId])
}

model FPOChatMessage {
  id                String    @id @default(uuid())
  chatId            String
  senderId          String
  content           String
  attachments       String[]
  read              Boolean   @default(false)
  createdAt         DateTime  @default(now())

  // Relations
  chat              FPOChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender            User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
}

// ─── FPO LOGISTICS ─────────────────────────────────────────────────────

model FPOLogistics {
  id                String    @id @default(uuid())
  orderId           String    @unique
  fpoId             String
  trackingNumber    String?
  carrier           String?
  status            String    @default("PENDING") // PENDING, PICKED_UP, IN_TRANSIT, OUT_FOR_DELIVERY, DELIVERED
  currentLocation   String?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fpo               FPO       @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  events            LogisticsEvent[]

  @@index([orderId])
  @@index([fpoId])
}

model LogisticsEvent {
  id                String    @id @default(uuid())
  logisticsId       String
  status            String
  location          String?
  description       String?
  timestamp         DateTime  @default(now())

  // Relations
  logistics         FPOLogistics @relation(fields: [logisticsId], references: [id], onDelete: Cascade)

  @@index([logisticsId])
}

// ─── FPO PAYOUT SPLIT ──────────────────────────────────────────────────

model FPOPayoutSplit {
  id                String    @id @default(uuid())
  orderId           String
  fpoId             String
  fpoFarmerId       String
  cropId            String
  farmerShare       Float     // Amount for farmer
  fpoCommission     Float     // FPO commission
  totalAmount       Float     // Total amount
  status            String    @default("PENDING") // PENDING, PAID
  paidAt            DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fpo               FPO       @relation(fields: [fpoId], references: [id], onDelete: Cascade)
  fpoFarmer         FPOFarmer @relation(fields: [fpoFarmerId], references: [id], onDelete: Cascade)
  crop              Crop      @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([fpoId])
  @@index([fpoFarmerId])
}
