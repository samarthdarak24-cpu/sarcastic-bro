{
  "name": "odop-connect",
  "version": "1.0.0",
  "description": "ODOP Connect Enterprise Agri-tech platform",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:ai": "cd apps/ai-service && python main.py",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\" -n \"WEB,API\" -c \"blue,green\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
