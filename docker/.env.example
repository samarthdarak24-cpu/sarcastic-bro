# ========================================================================
#  Environment Variables — ODOP Connect
#  Copy this file as .env and fill in production values.
# ========================================================================

# ─── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=odop
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=odopconnect

# ─── Backend ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://odop:change_me_in_production@postgres:5432/odopconnect?schema=public
JWT_ACCESS_SECRET=generate-a-secure-256-bit-secret-here
JWT_REFRESH_SECRET=generate-another-secure-256-bit-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=./uploads
ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_URL=redis://redis:6379

# ─── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_ENABLE_OFFLINE=true
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_S3_BUCKET_URL=http://localhost:9000/odop
